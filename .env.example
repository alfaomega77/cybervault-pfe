# CyberVault — copy to `.env` at the repository root

# Public URL used in email links
AISS_PUBLIC_URL=http://localhost:8090

# Shared secret for JumpServer → CyberVault webhook (/events)
AISS_WEBHOOK_TOKEN=replace-with-a-long-random-token

# Allow open registration (SaaS). Set false to lock new signups.
AISS_ALLOW_SIGNUP=true

# Local UI bind (public Internet access: use deployment/scripts/15-deploy-public.sh)
CYBERVAULT_BIND_ADDRESS=127.0.0.1
CYBERVAULT_PORT=8090

# --- Public deploy (optional) ---
# CYBERVAULT_DOMAIN=app.example.com
# CADDY_ACME_EMAIL=admin@example.com
# SITE_ADDRESS=http://:80
# CYBERVAULT_HTTP_PORT=80
# CYBERVAULT_HTTPS_PORT=443

# Email alerts (optional — alerts are still logged locally without SMTP)
AISS_SMTP_HOST=
AISS_SMTP_PORT=587
AISS_SMTP_TLS=true
AISS_SMTP_USER=
AISS_SMTP_PASSWORD=
AISS_SMTP_FROM=

# Optional JumpServer action API (lock / kill sessions outside dry-run)
AISS_JUMPSERVER_URL=
AISS_JUMPSERVER_TOKEN=

# Ava AI agent — general Q&A (tech, math, CyberVault). Leave empty = FAQ + local calculator only.
# OpenAI example:
# AISS_AGENT_LLM_URL=https://api.openai.com/v1/chat/completions
# AISS_AGENT_LLM_API_KEY=sk-...
# AISS_AGENT_LLM_MODEL=gpt-4o-mini
# Free local Ollama example (install Ollama, pull a model, then):
# AISS_AGENT_LLM_URL=http://host.docker.internal:11434/v1/chat/completions
# AISS_AGENT_LLM_API_KEY=ollama
# AISS_AGENT_LLM_MODEL=llama3.2
