# CyberVault — public Internet deployment
# Copy to `.env` at the repository root, then run:
#   bash deployment/scripts/15-deploy-public.sh

# --- Public URL (emails + absolute links) ---
# With a domain (HTTPS via Caddy / Let's Encrypt):
# CYBERVAULT_DOMAIN=app.example.com
# AISS_PUBLIC_URL=https://app.example.com
# CADDY_ACME_EMAIL=admin@example.com
#
# Without a domain (HTTP on port 80 — replace with your server IP):
AISS_PUBLIC_URL=http://YOUR_SERVER_PUBLIC_IP
CYBERVAULT_DOMAIN=
CADDY_ACME_EMAIL=
SITE_ADDRESS=http://:80

# Edge ports (host)
CYBERVAULT_HTTP_PORT=80
CYBERVAULT_HTTPS_PORT=443

# Shared secret for JumpServer → CyberVault webhook (/events)
# The public deploy script auto-generates a strong token if left as placeholder.
AISS_WEBHOOK_TOKEN=replace-with-a-long-random-token

# Open registration (SaaS-style)
AISS_ALLOW_SIGNUP=true

# Safe default: analyse + alerts only; set false when ready to lock/kill sessions
AISS_DRY_RUN=true

# Email alerts (optional)
AISS_SMTP_HOST=
AISS_SMTP_PORT=587
AISS_SMTP_TLS=true
AISS_SMTP_USER=
AISS_SMTP_PASSWORD=
AISS_SMTP_FROM=

# Optional global JumpServer defaults (clients usually set their own in Mon PAM)
AISS_JUMPSERVER_URL=
AISS_JUMPSERVER_TOKEN=
