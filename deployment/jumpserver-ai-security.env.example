# Copy to /opt/jumpserver/config/config.txt or append to JumpServer config.yml
# after installing the ai_security plugin into jms_core.

AI_SECURITY_ENABLED=true
AI_SECURITY_PUBLISHER=redis
AI_SECURITY_REDIS_CHANNEL=fm.security_events

# Alternative: HTTP webhook to AI Security Service (same Docker network)
# AI_SECURITY_PUBLISHER=http
# AI_SECURITY_WEBHOOK_URL=http://aiss:8090/events
