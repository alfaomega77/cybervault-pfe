# CyberVault — AWS EC2 POC environment (docker compose)

# Keep true for client demos unless change-managed
AISS_DRY_RUN=true

# JumpServer API (same host — adjust if core listens elsewhere)
AISS_JUMPSERVER_URL=http://127.0.0.1:8080
AISS_JUMPSERVER_TOKEN=

# Optional shared secret for webhook ingest
AISS_WEBHOOK_TOKEN=

# Public URL for email links / client browser
AISS_PUBLIC_URL=http://REPLACE_WITH_EC2_EIP:8090

# Notifications (optional)
# AISS_SMTP_HOST=
# AISS_SMTP_USER=
# AISS_SMTP_PASSWORD=
