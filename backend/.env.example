# CyberVault — notifications email

# Email (Gmail : smtp.gmail.com + mot de passe d'application)
AISS_SMTP_HOST=smtp.gmail.com
AISS_SMTP_PORT=587
AISS_SMTP_TLS=true
AISS_SMTP_USER=alerts@example.com
AISS_SMTP_PASSWORD=replace-with-an-app-password
AISS_SMTP_FROM="CyberVault <alerts@example.com>"

# URL publique pour les liens dans les emails
AISS_PUBLIC_URL=http://localhost:8090
AISS_WEBHOOK_TOKEN=replace-with-a-long-random-token
